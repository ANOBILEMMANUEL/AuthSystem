<%- include('partials/header') %>

<div class="landing-wrapper">
    <!-- SECTION 1: HERO CONTAINER -->
    <header class="hero-section">
        <div class="hero-content">
            <span class="badge">Next-Gen Identity Layer</span>
            <h1>Secure Authentication <br><span class="accent-text">Built For Scale</span></h1>
            <p>An enterprise-ready login, registration, and session token ecosystem. Engineered using Node.js, Passport encryption protocols, and optimized MongoDB architectures.</p>
            <div class="cta-group">
                <a href="/signup" class="btn btn-primary">Get Started Free</a>
                <a href="/login" class="btn btn-secondary">Account Portal</a>
            </div>
        </div>
        <div class="hero-visual">
            <div class="visual-cube-container">
                <div class="floating-cube">🔒</div>
                <div class="glow-orb"></div>
            </div>
        </div>
    </header>

    <!-- SECTION 2: METRICS / STATUS -->
    <section class="metrics-section">
        <div class="metric-card">
            <h3>99.99%</h3>
            <p>Uptime Integrity</p>
        </div>
        <div class="metric-card">
            <h3>&lt; 45ms</h3>
            <p>Token Validation</p>
        </div>
        <div class="metric-card">
            <h3>PBKDF2</h3>
            <p>Hashing Algorithm</p>
        </div>
    </section>

    <!-- SECTION 3: FEATURE MATRIX -->
    <section class="features-section">
        <div class="section-heading">
            <h2>Engineered For Security</h2>
            <p>Explore the layers powering your dynamic user ecosystem.</p>
        </div>
        <div class="feature-grid">
            <div class="feature-card">
                <div class="icon">🔑</div>
                <h3>Email-Key Mapping</h3>
                <p>Advanced credential identification utilizing modern email strings as the base validation mechanism instead of generic usernames.</p>
            </div>
            <div class="feature-card">
                <div class="icon">🛡️</div>
                <h3>Passport.js Shield</h3>
                <p>Dynamic middleware abstractions handling cross-site validation protocols, injection defense, and native cookies.</p>
            </div>
            <div class="feature-card">
                <div class="icon">💾</div>
                <h3>Mongoose Buffering</h3>
                <p>Fault-tolerant persistent structures handling safe operations even during network configuration re-assignments.</p>
            </div>
        </div>
    </section>

    <!-- SECTION 4: HOW IT WORKS (WORKFLOW) -->
    <section class="workflow-section">
        <div class="section-heading">
            <h2>The Lifecycle</h2>
        </div>
        <div class="workflow-steps">
            <div class="step">
                <div class="step-number">01</div>
                <h4>Secure Handshake</h4>
                <p>Credentials run through standard input sanity checks to strip illegal script injections.</p>
            </div>
            <div class="step">
                <div class="step-number">02</div>
                <h4>Salting & Cryptography</h4>
                <p>The core plugin generates automatic salt bytes and cryptographically shreds passwords.</p>
            </div>
            <div class="step">
                <div class="step-number">03</div>
                <h4>Session Grant</h4>
                <p>A session tracking identification token is assigned, enabling immediate dashboard clearance entries.</p>
            </div>
        </div>
    </section>

    <!-- SECTION 5: FAULT ISOLATION INFOBAR -->
    <section class="info-banner-section">
        <div class="banner-box">
            <h3>Looking for live performance parameters?</h3>
            <p>The platform runs internal validation loops preventing system crashes during multi-account entry bursts.</p>
            <a href="/login" class="inline-link">Access Sandbox Framework &rarr;</a>
        </div>
    </section>

    <!-- SECTION 6: CONTEXT CALL-TO-ACTION (CTA) -->
    <section class="bottom-cta-section">
        <div class="cta-card">
            <h2>Deploy Your Identity Control Plane</h2>
            <p>Launch the node stack, link your Atlas configuration instances, and onboard users instantly.</p>
            <a href="/signup" class="btn btn-primary long-btn">Initialize New Workspace</a>
        </div>
    </section>
</div>

<%- include('partials/footer') %>