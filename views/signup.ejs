<%- include('partials/header') -%>

<div class="auth-container">
    <div class="auth-box">
        <form action="/signup" method="POST" class="auth-form">
             <%- include('partials/messages') -%>
            <h2>Sign Up</h2>

            <div class="form-inputs-group">
                <div class="form-group">
                    <input type="text" id="username" name="username" placeholder="Username" required>
                </div>

                <div class="form-group">
                    <input type="email" id="email" name="email" placeholder="Email Address" required>
                </div>

                <div class="form-group">
                    <input type="password" id="password" name="password" placeholder="Password" required>
                </div>

                <button type="submit" class="auth-btn auth-btn-primary">Sign Up</button>
            </div>

            <div class="auth-separator">OR</div>

            <div class="form-actions-group">
                <button type="button" class="auth-btn auth-btn-signup" onclick="window.location.href='/login'">Login</button>
            </div>
        </form>
    </div>
</div>

<%- include('partials/footer') -%>